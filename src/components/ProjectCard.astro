---
type Props = {
  href: string;
  title: string;
  description?: string;
  year?: number;
  tags?: string[];
};

const { href, title, description, year, tags } = Astro.props as Props;
---

<a
  href={href}
  class="group block rounded-2xl border border-slate-200 bg-white/60 p-5 transition hover:border-slate-300 hover:bg-white"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-base font-semibold tracking-tight group-hover:text-slate-900">
        {title}
      </h2>
      {description ? (
        <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-700">{description}</p>
      ) : null}
    </div>

    {year ? <div class="shrink-0 text-xs text-slate-500">{year}</div> : null}
  </div>

  {tags && tags.length ? (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.slice(0, 6).map((t) => (
        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] text-slate-600">
          {t}
        </span>
      ))}
    </div>
  ) : null}
</a>

